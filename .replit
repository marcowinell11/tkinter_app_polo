modules = ["python-3.12"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["python312Packages.tkinter"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "vnc"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PYTHONPATH=/nix/store/izkldz9a5b7kbdlgfm1n7zrmmp6ihs1m-python3.12-tkinter-3.12.11/lib/python3.12/site-packages:$PYTHONPATH python3 app.py"

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "PYTHONPATH=/nix/store/izkldz9a5b7kbdlgfm1n7zrmmp6ihs1m-python3.12-tkinter-3.12.11/lib/python3.12/site-packages:$PYTHONPATH python3 app.py"]
